{
  "$schema": "vscode://schemas/color-theme",
  "name": "Morning Brew — Mocha",
  "type": "dark",
  "semanticHighlighting": true,
  "colors": {
    "//": "===== Base =====",
    "foreground": "#E9D8BF",
    "focusBorder": "#C57B33",
    "errorForeground": "#EF7B63",
    "descriptionForeground": "#B49A80",
    "icon.foreground": "#C9B79C",
    "selection.background": "#4A3320",
    "widget.shadow": "#00000060",

    "//editor": "===== Editor =====",
    "editor.background": "#271A12",
    "editor.foreground": "#E9D8BF",
    "editorLineNumber.foreground": "#6B5540",
    "editorLineNumber.activeForeground": "#E0A85B",
    "editorCursor.foreground": "#E0A85B",
    "editor.selectionBackground": "#4A3320",
    "editor.selectionHighlightBackground": "#3A281A88",
    "editor.wordHighlightBackground": "#4A332055",
    "editor.wordHighlightStrongBackground": "#5A3E2455",
    "editor.findMatchBackground": "#B5652A",
    "editor.findMatchHighlightBackground": "#C57B3355",
    "editor.lineHighlightBackground": "#32221780",
    "editor.rangeHighlightBackground": "#3A281A66",
    "editorWhitespace.foreground": "#3E2C1E",
    "editorIndentGuide.background1": "#3A2A1E",
    "editorIndentGuide.activeBackground1": "#6F5030",
    "editorRuler.foreground": "#3A2A1E",
    "editorBracketMatch.background": "#4A332055",
    "editorBracketMatch.border": "#C57B33",
    "editorLink.activeForeground": "#E0A85B",

    "//gutter": "===== Gutter / diff =====",
    "editorGutter.modifiedBackground": "#E08A4E",
    "editorGutter.addedBackground": "#9BB86B",
    "editorGutter.deletedBackground": "#EF7B63",
    "editorError.foreground": "#EF7B63",
    "editorWarning.foreground": "#E0A85B",
    "editorInfo.foreground": "#7FC9B0",

    "//sidebar": "===== Side bar =====",
    "sideBar.background": "#20140D",
    "sideBar.foreground": "#C9B79C",
    "sideBar.border": "#160E08",
    "sideBarTitle.foreground": "#E0A85B",
    "sideBarSectionHeader.background": "#2C1D13",
    "sideBarSectionHeader.foreground": "#E9D8BF",

    "//activitybar": "===== Activity bar =====",
    "activityBar.background": "#1D110B",
    "activityBar.foreground": "#E0A85B",
    "activityBar.inactiveForeground": "#8A7259",
    "activityBar.border": "#160E08",
    "activityBarBadge.background": "#E0728F",
    "activityBarBadge.foreground": "#2A1B10",

    "//statusbar": "===== Status bar (bold caramel) =====",
    "statusBar.background": "#B5652A",
    "statusBar.foreground": "#FDF3E4",
    "statusBar.border": "#8A4A1C",
    "statusBar.noFolderBackground": "#8A4A1C",
    "statusBar.debuggingBackground": "#E0728F",
    "statusBar.debuggingForeground": "#2A1B10",
    "statusBarItem.remoteBackground": "#8A4A1C",
    "statusBarItem.remoteForeground": "#FDF3E4",

    "//titlebar": "===== Title bar =====",
    "titleBar.activeBackground": "#1D110B",
    "titleBar.activeForeground": "#E9D8BF",
    "titleBar.inactiveBackground": "#20140D",
    "titleBar.inactiveForeground": "#8A7259",
    "titleBar.border": "#160E08",

    "//tabs": "===== Editor tabs =====",
    "editorGroupHeader.tabsBackground": "#1D110B",
    "editorGroupHeader.tabsBorder": "#160E08",
    "editorGroup.border": "#160E08",
    "tab.activeBackground": "#271A12",
    "tab.inactiveBackground": "#1F140D",
    "tab.activeForeground": "#F3E6D2",
    "tab.inactiveForeground": "#8A7259",
    "tab.border": "#160E08",
    "tab.activeBorderTop": "#C57B33",
    "tab.hoverBackground": "#2E1F15",

    "//panel": "===== Panels =====",
    "panel.background": "#20140D",
    "panel.border": "#160E08",
    "panelTitle.activeForeground": "#E9D8BF",
    "panelTitle.inactiveForeground": "#8A7259",

    "//inputs": "===== Inputs / dropdowns / buttons =====",
    "input.background": "#1F140D",
    "input.foreground": "#E9D8BF",
    "input.border": "#3E2C1E",
    "input.placeholderForeground": "#8A7259",
    "dropdown.background": "#1F140D",
    "dropdown.foreground": "#E9D8BF",
    "dropdown.border": "#3E2C1E",
    "button.background": "#C57B33",
    "button.foreground": "#2A1B10",
    "button.hoverBackground": "#D68F45",
    "button.secondaryBackground": "#3E2C1E",
    "button.secondaryForeground": "#E9D8BF",
    "badge.background": "#E0728F",
    "badge.foreground": "#2A1B10",
    "progressBar.background": "#C57B33",

    "//lists": "===== Lists / trees =====",
    "list.activeSelectionBackground": "#3E2A1B",
    "list.activeSelectionForeground": "#F3E6D2",
    "list.inactiveSelectionBackground": "#2E1F15",
    "list.inactiveSelectionForeground": "#E9D8BF",
    "list.hoverBackground": "#2E1F15",
    "list.focusBackground": "#3E2A1B",
    "list.highlightForeground": "#E0A85B",
    "list.errorForeground": "#EF7B63",
    "list.warningForeground": "#E0A85B",
    "tree.indentGuidesStroke": "#3E2C1E",

    "//widgets": "===== Widgets / suggest =====",
    "editorWidget.background": "#1F140D",
    "editorWidget.border": "#3E2C1E",
    "editorSuggestWidget.background": "#1F140D",
    "editorSuggestWidget.border": "#3E2C1E",
    "editorSuggestWidget.selectedBackground": "#3E2A1B",
    "editorSuggestWidget.highlightForeground": "#E0A85B",
    "editorHoverWidget.background": "#1F140D",
    "editorHoverWidget.border": "#3E2C1E",
    "peekView.border": "#C57B33",
    "peekViewEditor.background": "#20140D",
    "peekViewResult.background": "#1D110B",
    "peekViewTitle.background": "#2C1D13",

    "//scrollbar": "===== Scrollbar / minimap =====",
    "scrollbar.shadow": "#00000060",
    "scrollbarSlider.background": "#6F503044",
    "scrollbarSlider.hoverBackground": "#6F503088",
    "scrollbarSlider.activeBackground": "#C57B3388",
    "minimap.findMatchHighlight": "#C57B33",
    "minimapSlider.background": "#6F503044",

    "//terminal": "===== Terminal (coffee ANSI) =====",
    "terminal.background": "#271A12",
    "terminal.foreground": "#E9D8BF",
    "terminal.ansiBlack": "#3E2C1E",
    "terminal.ansiRed": "#E0728F",
    "terminal.ansiGreen": "#9BB86B",
    "terminal.ansiYellow": "#E0A85B",
    "terminal.ansiBlue": "#7FC9B0",
    "terminal.ansiMagenta": "#C79BE0",
    "terminal.ansiCyan": "#8FD4C0",
    "terminal.ansiWhite": "#E9D8BF",
    "terminal.ansiBrightBlack": "#8A7259",
    "terminal.ansiBrightRed": "#EF8AA3",
    "terminal.ansiBrightGreen": "#B0CB7A",
    "terminal.ansiBrightYellow": "#EEBE77",
    "terminal.ansiBrightBlue": "#95D6C1",
    "terminal.ansiBrightMagenta": "#D6B2EC",
    "terminal.ansiBrightCyan": "#A5E0D0",
    "terminal.ansiBrightWhite": "#F3E6D2",
    "terminal.selectionBackground": "#4A3320",

    "//brackets": "===== Bracket pair colours (coffee, not rainbow) =====",
    "editorBracketHighlight.foreground1": "#E0A85B",
    "editorBracketHighlight.foreground2": "#E0728F",
    "editorBracketHighlight.foreground3": "#C79BE0",
    "editorBracketHighlight.foreground4": "#9BB86B",
    "editorBracketHighlight.foreground5": "#7FC9B0",
    "editorBracketHighlight.foreground6": "#D9A17A",
    "editorBracketHighlight.unexpectedBracket.foreground": "#EF7B63",
    "editorBracketPairGuide.background1": "#E0A85B33",
    "editorBracketPairGuide.activeBackground1": "#E0A85B66",

    "//inlayhints": "===== Inlay hints (type / parameter) =====",
    "editorInlayHint.foreground": "#8A7259",
    "editorInlayHint.background": "#00000000",
    "editorInlayHint.typeForeground": "#9A8468",
    "editorInlayHint.parameterForeground": "#9A8468",

    "//git": "===== Git decorations =====",
    "gitDecoration.modifiedResourceForeground": "#E0A85B",
    "gitDecoration.untrackedResourceForeground": "#9BB86B",
    "gitDecoration.deletedResourceForeground": "#EF7B63",
    "gitDecoration.ignoredResourceForeground": "#6B5540",
    "gitDecoration.conflictingResourceForeground": "#E08A4E"
  },
  "tokenColors": [
    {
      "name": "Comment",
      "scope": ["comment", "punctuation.definition.comment"],
      "settings": { "foreground": "#8A7259", "fontStyle": "italic" }
    },
    {
      "name": "String",
      "scope": ["string", "string.quoted", "punctuation.definition.string"],
      "settings": { "foreground": "#9BB86B" }
    },
    {
      "name": "String escape / template expression",
      "scope": ["constant.character.escape", "punctuation.definition.template-expression"],
      "settings": { "foreground": "#E0A85B" }
    },
    {
      "name": "Number / numeric constant",
      "scope": ["constant.numeric", "constant.other.unit"],
      "settings": { "foreground": "#E08A4E" }
    },
    {
      "name": "Boolean / null / language constant",
      "scope": ["constant.language", "support.constant"],
      "settings": { "foreground": "#E0728F" }
    },
    {
      "name": "Keyword / control flow",
      "scope": ["keyword", "keyword.control", "keyword.other"],
      "settings": { "foreground": "#E0728F", "fontStyle": "bold" }
    },
    {
      "name": "Operator",
      "scope": ["keyword.operator"],
      "settings": { "foreground": "#D9A17A" }
    },
    {
      "name": "Storage (const/let/function/class keywords) & types",
      "scope": ["storage", "storage.type", "storage.modifier"],
      "settings": { "foreground": "#C79BE0", "fontStyle": "bold" }
    },
    {
      "name": "Type / class / interface names",
      "scope": [
        "entity.name.type",
        "entity.name.class",
        "support.type",
        "support.class",
        "entity.other.inherited-class"
      ],
      "settings": { "foreground": "#C79BE0" }
    },
    {
      "name": "Function / method names",
      "scope": [
        "entity.name.function",
        "support.function",
        "meta.function-call entity.name.function"
      ],
      "settings": { "foreground": "#E0A85B" }
    },
    {
      "name": "Variables",
      "scope": ["variable", "meta.definition.variable.name", "variable.other.readwrite"],
      "settings": { "foreground": "#E9D8BF" }
    },
    {
      "name": "Function parameters",
      "scope": ["variable.parameter"],
      "settings": { "foreground": "#E4B98C", "fontStyle": "italic" }
    },
    {
      "name": "Object property / member",
      "scope": ["variable.other.property", "variable.other.object.property", "support.variable.property"],
      "settings": { "foreground": "#7FC9B0" }
    },
    {
      "name": "Language variable (this/self/super)",
      "scope": ["variable.language"],
      "settings": { "foreground": "#E0728F", "fontStyle": "italic" }
    },
    {
      "name": "Punctuation",
      "scope": ["punctuation", "meta.brace", "punctuation.separator", "punctuation.terminator"],
      "settings": { "foreground": "#B49A80" }
    },
    {
      "name": "HTML/XML tags",
      "scope": ["entity.name.tag", "punctuation.definition.tag"],
      "settings": { "foreground": "#E0728F" }
    },
    {
      "name": "Tag attributes",
      "scope": ["entity.other.attribute-name"],
      "settings": { "foreground": "#E0A85B", "fontStyle": "italic" }
    },
    {
      "name": "JSON / object keys",
      "scope": ["support.type.property-name.json", "meta.object-literal.key", "support.type.property-name"],
      "settings": { "foreground": "#E0A85B" }
    },
    {
      "name": "Decorators / annotations",
      "scope": ["meta.decorator", "punctuation.decorator", "entity.name.function.decorator"],
      "settings": { "foreground": "#E08A4E" }
    },
    {
      "name": "Regular expressions",
      "scope": ["string.regexp", "constant.other.character-class.regexp"],
      "settings": { "foreground": "#7FC9B0" }
    },
    {
      "name": "Invalid",
      "scope": ["invalid", "invalid.illegal"],
      "settings": { "foreground": "#EF7B63" }
    },
    {
      "name": "Markdown heading",
      "scope": ["markup.heading", "entity.name.section.markdown"],
      "settings": { "foreground": "#E0728F", "fontStyle": "bold" }
    },
    {
      "name": "Markdown bold",
      "scope": ["markup.bold"],
      "settings": { "foreground": "#E08A4E", "fontStyle": "bold" }
    },
    {
      "name": "Markdown italic",
      "scope": ["markup.italic"],
      "settings": { "foreground": "#C79BE0", "fontStyle": "italic" }
    },
    {
      "name": "Markdown link",
      "scope": ["markup.underline.link", "string.other.link"],
      "settings": { "foreground": "#E0A85B" }
    },
    {
      "name": "Markdown code / quote",
      "scope": ["markup.inline.raw", "markup.fenced_code", "markup.quote"],
      "settings": { "foreground": "#9BB86B" }
    },
    {
      "name": "Diff inserted",
      "scope": ["markup.inserted"],
      "settings": { "foreground": "#9BB86B" }
    },
    {
      "name": "Diff deleted",
      "scope": ["markup.deleted"],
      "settings": { "foreground": "#EF7B63" }
    }
  ]
}
